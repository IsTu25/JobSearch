# Google Gemini API (chat, CV analysis, roadmap, embeddings)
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Serper.dev (Google Jobs API — powers job search)
# Get free key at: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# Adzuna Job Board API (salary data, global coverage)
# Get free keys at: https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# Supabase (optional — for persistent storage)
# Get free project at: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
